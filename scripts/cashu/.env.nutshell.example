# Local Cashu mint config for Eventinel dev testing.
# Copy to .env.nutshell and customize if needed.

# Keep loopback for safety. Set 0.0.0.0 only when testing from physical devices.
MINT_HOST_BIND=127.0.0.1
MINT_LISTEN_PORT=3338
MINT_BACKEND_BOLT11_SAT=FakeWallet

# Dev key only; never reuse production keys.
MINT_PRIVATE_KEY=TEST_PRIVATE_KEY_CHANGE_ME

# CLI defaults to the compose service name so it can reach the local mint.
CASHU_CLI_MINT_URL=http://nutshell-dev:3338
