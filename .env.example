# Eventinel Mobile - Environment Variables
# Copy this file to .env.local for local development
# Use .env for production builds

# Mapbox access token (get from https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Nostr relay URLs (comma-separated)
# Default relay (production)
EXPO_PUBLIC_NOSTR_RELAYS=wss://relay.eventinel.com

# Local relay URLs for dev toggle (comma-separated)
# Android emulator: ws://10.0.0.197:8085
# iOS simulator: ws://localhost:8085
# Default: Android emulator local relay (override in .env.local if needed)
EXPO_PUBLIC_LOCAL_RELAYS=ws://10.0.0.197:8085

# Dev-only wallet feature flags (ignored in production because code gates on __DEV__)
# Accepted values: 1/0, true/false, yes/no, on/off
EXPO_PUBLIC_ENABLE_LIGHTNING_WALLET=1
EXPO_PUBLIC_ENABLE_CASHU_WALLET=1

# Optional: NIP-96 media upload endpoint for images/videos attached to comments
# Example:
# EVENTINEL_NIP96_ENDPOINT=https://your-nip96-server.example/api/v2/nip96
EVENTINEL_NIP96_ENDPOINT=
