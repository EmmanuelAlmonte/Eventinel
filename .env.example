# Eventinel Mobile - Environment Variables
# Copy this file to .env.local for local development
# Use .env for production builds

# Mapbox access token (get from https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Nostr relay URLs (comma-separated)
NEXT_PUBLIC_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band
