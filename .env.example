# Eventinel Mobile - Environment Variables
# Copy this file to .env.local for local development
# Use .env for production builds

# Mapbox access token (get from https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Nostr relay URLs (comma-separated)
# Default relay (production)
EXPO_PUBLIC_NOSTR_RELAYS=wss://relay.eventinel.com

# Local relay URLs for dev toggle (comma-separated)
# Android emulator: ws://10.0.2.2:8085
# iOS simulator: ws://localhost:8085
# Default: same as production (override in .env.local if you run a local relay)
EXPO_PUBLIC_LOCAL_RELAYS=wss://relay.eventinel.com

# DVM integration (optional)
# Enable DVM request/result flow in useIncidentSubscription
EXPO_PUBLIC_USE_DVM_GEO_QUERY=false

# Response mode requested from DVM:
# refs_only | enriched | both
EXPO_PUBLIC_DVM_RESPONSE_MODE=enriched

# Nearby display radius for non-DVM mode (miles), clamped to [0.05, 50]
EXPO_PUBLIC_INCIDENT_RADIUS_MILES=5

# Optional: NIP-96 media upload endpoint for images/videos attached to comments
# Example:
# EVENTINEL_NIP96_ENDPOINT=https://your-nip96-server.example/api/v2/nip96
EVENTINEL_NIP96_ENDPOINT=
