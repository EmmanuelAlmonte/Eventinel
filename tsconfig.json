{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@screens": ["screens"],
      "@screens/*": ["screens/*"],
      "@hooks": ["hooks"],
      "@hooks/*": ["hooks/*"],
      "@lib": ["lib"],
      "@lib/*": ["lib/*"]
    }
  },
  "exclude": [
    "node_modules",
    "do/**/*",
    "do",
    "docs/**/*",
    "docs",
    "os/**/*",
    "os"
  ]
}
