{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@nostr-dev-kit/mobile": ["node_modules/@nostr-dev-kit/ndk-mobile"],
      "@nostr-dev-kit/mobile/*": ["node_modules/@nostr-dev-kit/ndk-mobile/*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@contexts": ["contexts"],
      "@contexts/*": ["contexts/*"],
      "@screens": ["screens"],
      "@screens/*": ["screens/*"],
      "@hooks": ["hooks"],
      "@hooks/*": ["hooks/*"],
      "@lib": ["lib"],
      "@lib/*": ["lib/*"]
    }
  },
  "exclude": [
    "node_modules",
    "do/**/*",
    "do",
    "docs/**/*",
    "docs",
    "os/**/*",
    "os"
  ]
}
